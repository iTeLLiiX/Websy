{
  "name": "websitbuilder",
  "version": "1.0.0",
  "description": "KI-Website-Builder für deutsche Kleinunternehmen",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "npm run start:backend",
    "start:backend": "cd backend && npm run start",
    "start:frontend": "cd frontend && npm run start",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "setup": "npm run install:all && npm run db:generate",
    "db:generate": "cd backend && npm run db:generate",
    "db:push": "cd backend && npm run db:push",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:setup": "cd backend && npm run db:setup",
    "db:test": "cd backend && npm run db:test",
    "deploy:prepare": "node scripts/deploy.js",
    "deploy:frontend": "cd frontend && npm run build",
    "deploy:backend": "cd backend && npm run build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "website-builder",
    "ai",
    "restaurant",
    "germany",
    "small-business"
  ],
  "author": "WebsiteBuilder AI Team",
  "license": "MIT"
}