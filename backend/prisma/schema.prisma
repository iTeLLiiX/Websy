// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  avatar        String?
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  websites      Website[]
  subscriptions Subscription[]
  analytics     Analytics[]
  payments      Payment[]
  files         File[]

  @@map("users")
}

model Website {
  id          String   @id @default(cuid())
  name        String
  domain      String   @unique
  subdomain   String   @unique
  customDomain String?
  status      String   @default("draft") // draft, published, archived
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Foreign keys
  userId      String
  templateId  String

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template    Template  @relation(fields: [templateId], references: [id])
  pages       Page[]
  settings    WebsiteSettings?
  analytics   Analytics[]
  files       File[]

  @@map("websites")
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  thumbnail   String
  preview     String?
  features    String   // JSON string of features array
  isPremium   Boolean  @default(false)
  tags        String   // JSON string of tags array
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  pages       Page[]
  websites    Website[]

  @@map("templates")
}

model Page {
  id          String   @id @default(cuid())
  name        String
  slug        String
  isHomePage  Boolean  @default(false)
  isPublished Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Foreign keys
  websiteId   String
  templateId  String?

  // Relations
  website     Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  template    Template? @relation(fields: [templateId], references: [id])
  sections    Section[]

  @@map("pages")
}

model Section {
  id        String   @id @default(cuid())
  type      String   // hero, about, services, contact, etc.
  content   String   // JSON string of content
  settings  String   // JSON string of settings
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Foreign keys
  pageId    String

  // Relations
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@map("sections")
}

model WebsiteSettings {
  id        String   @id @default(cuid())
  theme     String   // JSON string of theme configuration
  seo       String   // JSON string of SEO settings
  integrations String // JSON string of integrations
  aiSettings String  // JSON string of AI settings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Foreign keys
  websiteId String   @unique

  // Relations
  website   Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@map("website_settings")
}

model Subscription {
  id                    String    @id @default(cuid())
  plan                  String    @default("FREE") // FREE, STARTER, PROFESSIONAL, BUSINESS
  status                String    @default("ACTIVE") // ACTIVE, CANCELED, PAST_DUE, INCOMPLETE
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean   @default(false)
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Foreign keys
  userId                String    @unique

  // Relations
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Payment {
  id              String   @id @default(cuid())
  amount          Int      // Amount in cents
  currency        String   @default("EUR")
  status          String   // COMPLETED, FAILED, PENDING, CANCELED
  description     String?
  stripePaymentId String?
  metadata        String?  // JSON string of metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Foreign keys
  userId          String

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Analytics {
  id        String   @id @default(cuid())
  event     String   // page_view, click, form_submit, etc.
  data      String   // JSON string of event data
  ipAddress String?
  userAgent String?
  referer   String?
  createdAt DateTime @default(now())

  // Foreign keys
  userId    String
  websiteId String

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  website   Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@map("analytics")
}

model File {
  id           String   @id @default(cuid())
  originalName String
  filename     String
  mimetype     String
  size         Int
  path         String
  url          String
  type         String   @default("image") // image, document, logo, background
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Foreign keys
  userId       String
  websiteId    String

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  website      Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@map("files")
}