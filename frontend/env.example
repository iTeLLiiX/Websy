# API Configuration
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key-here"

# OpenAI (Optional - for client-side features)
NEXT_PUBLIC_OPENAI_API_KEY="sk-your-openai-api-key-here"

# Google Analytics
NEXT_PUBLIC_GA_ID="GA-XXXXXXXXX"
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Social Media
NEXT_PUBLIC_FACEBOOK_APP_ID="your-facebook-app-id"
NEXT_PUBLIC_INSTAGRAM_ACCESS_TOKEN="your-instagram-access-token"

# App Configuration
NEXT_PUBLIC_APP_NAME="WebsiteBuilder AI"
NEXT_PUBLIC_APP_DESCRIPTION="Der einfachste KI-Website-Builder für deutsche Kleinunternehmen"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_FEATURES="true"
NEXT_PUBLIC_ENABLE_VOICE_INPUT="true"
NEXT_PUBLIC_ENABLE_PHOTO_UPLOAD="true"
NEXT_PUBLIC_ENABLE_CHAT_EDITING="true"

# Environment
NODE_ENV="development"

# Sentry (Optional - for error tracking)
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Cloudflare (Optional - for CDN)
NEXT_PUBLIC_CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"

# AWS S3 (Optional - for file uploads)
NEXT_PUBLIC_AWS_S3_BUCKET="websitbuilder-uploads"
NEXT_PUBLIC_AWS_REGION="eu-central-1"

# Email
NEXT_PUBLIC_CONTACT_EMAIL="support@websitbuilder.ai"
NEXT_PUBLIC_SALES_EMAIL="sales@websitbuilder.ai"

# Support
NEXT_PUBLIC_SUPPORT_URL="https://help.websitbuilder.ai"
NEXT_PUBLIC_DOCS_URL="https://docs.websitbuilder.ai"

# Legal
NEXT_PUBLIC_PRIVACY_POLICY_URL="https://websitbuilder.ai/privacy"
NEXT_PUBLIC_TERMS_OF_SERVICE_URL="https://websitbuilder.ai/terms"
NEXT_PUBLIC_IMPRINT_URL="https://websitbuilder.ai/imprint"

# Pricing
NEXT_PUBLIC_STARTER_PRICE="9"
NEXT_PUBLIC_PROFESSIONAL_PRICE="19"
NEXT_PUBLIC_BUSINESS_PRICE="39"

# Currency
NEXT_PUBLIC_CURRENCY="EUR"
NEXT_PUBLIC_CURRENCY_SYMBOL="€"

# Locale
NEXT_PUBLIC_LOCALE="de-DE"
NEXT_PUBLIC_TIMEZONE="Europe/Berlin"

# Performance
NEXT_PUBLIC_ENABLE_ANALYTICS="true"
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING="true"

# Security
NEXT_PUBLIC_CSP_NONCE="your-csp-nonce-here"

# Development
NEXT_PUBLIC_DEBUG="false"
NEXT_PUBLIC_VERBOSE_LOGGING="false"